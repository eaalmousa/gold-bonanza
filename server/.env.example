# =============================================
# Binance API Configuration
# =============================================
# For LIVE trading: https://fapi.binance.com
# For TESTNET:      https://testnet.binancefuture.com
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_BASE_URL=https://fapi.binance.com

# =============================================
# Auth (generate a strong jwt secret & hash a password with bcrypt)
# =============================================
JWT_SECRET=super_secret_jwt_key_change_this
LOGIN_PASSWORD_HASH=$2b$10$your_bcrypt_hashed_password_here

# =============================================
# Trading Risk Configuration (can also be changed live in the UI)
# =============================================
RISK_PER_TRADE=0.04
MAX_CONCURRENT_TRADES=4
LEVERAGE=5
MIN_SCORE_TO_DEPLOY=17
BASE_CAPITAL=300
